generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

model FormSubmission {
  formSubmissionId String      @id @default(cuid())
  formType         String   // enquiry | contact

  firstName        String?
  lastName         String?
  fullName         String?
  email            String?
  phone            String?

  serviceRequired  String?
  comments         String?
  message          String?

  createdAt        DateTime @default(now())
}

model Notification {
  notificationId String   @id @default(cuid())

  title          String
  description    String?
  redirectUrl    String?

  userId         String?
  user           User?      @relation(fields: [userId], references: [userId])

  employeeId     String?
  employee       Employee?  @relation(fields: [employeeId], references: [employeeId])

  isRead         Boolean    @default(false)

  createdAt      DateTime   @default(now())
}

model Blog {
  blogId      String   @id @default(cuid())
  title       String
  description String?
  content     Json
  author      String
  thumbnail   String? 

  slug        String   @unique
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailConfig {
  EmailConfig         String      @id @default(cuid())
  provider   String   // resend or ses
  apiKey     String?
  accessKey  String?
  secretKey  String?
  region     String?
  fromEmail  String
  createdAt  DateTime @default(now())
}

model EmailEvent {
  eventId   String   @id @default(cuid())
  name      String   @unique
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PaymentSetting {
  paymentSettingId   String   @id @default(cuid())
  isRazorpayEnabled  Boolean  @default(true)
  razorpayKeyId      String?
  razorpaySecret     String?
  mode               String?
  webhookId         String?  // store webhook ID from Razorpay
  webhookSecret     String?  // store webhook secret securely
  alertEmail        String?   // <-- new field
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum MyServiceStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum Role {
  USER
  STAFF
  ADMIN
}

enum DurationUnit {
  MONTH
  YEAR
}

enum Frequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum StepStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
}

enum ApplicationStatus {
  PENDING
  ASSIGNED
  PROCESSING
  REASSIGNED
  COMPLETED
  REJECTED
}

enum Provider {
  EMAIL
  GOOGLE
}


model User {
  userId      String    @id @unique @default(cuid())
  name        String
  email       String    @unique
  phoneNumber String?  
  password    String? // hashed password

  photoUrl    String?


  // 🔐 Password Reset
  resetToken        String?
  resetTokenExpiry  DateTime?

  provider    Provider @default(EMAIL)
  providerId  String?  // Google sub id

  role        Role      @default(USER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  notification Notification[]
  myServices  MyService[]   // ✅ relation
  applications Application[] // ✅ relation
  payments   Payment[]
  refreshToken RefreshToken[]

}

model RefreshToken {
  refreshTokenId        String   @id @default(cuid())
  token     String @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  userId    String?
  user      User?     @relation(fields: [userId], references: [userId])
  employeeId String?
  employee  Employee? @relation(fields: [employeeId], references: [employeeId])
}

model Payment {
  paymentId String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [userId])

  createdById String?
  createdBy   Employee? @relation( fields: [createdById], references: [employeeId])


  // what user is paying for
  serviceId String?
  bundleId  String?

  type  String?

  amount Float

  status String @default("PENDING") 
  // PENDING | PAID | FAILED

  razorpayOrderId   String? @unique
  razorpayPaymentId String?
  razorpayPaymentLink String? // ✅ Rename from paymentLink to this
  
  // Error tracking for failed payments
  errorDescription String? // ✅ NEW
  errorCode        String? // ✅ NEW

  paidAt DateTime?
  createdAt DateTime @default(now())
}

model Department {
  departmentId   String     @id @unique @default(cuid())
  name           String
  departmentCode String
  labelColor     String // store HEX or any color value
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  Employee       Employee[]
}

model Employee {
  employeeId   String         @id @unique @default(cuid())
  employeeCode String?  @unique
  name         String
  email        String         @unique
  password     String
  mobileNumber String
  role         Role
  profilePassword String?                       
  resetToken        String?    // 🔐 Password Reset
  resetTokenExpiry  DateTime?
  designation  String
  status       EmployeeStatus @default(ACTIVE)
  photoUrl     String?
  departmentId String
  department   Department     @relation(fields: [departmentId], references: [departmentId])
  service Service[]
  application Application[]

  payment  Payment[]
  notification Notification[]

    // ✅ ADD THESE TWO LINES
  applicationTrackStepsUpdated ApplicationTrackStep[]
  periodStepsUpdated           PeriodStep[]
  refreshToken RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


//
// =====================================
// CATEGORY
// =====================================
//
model Category {
  categoryId    String        @id @default(cuid())
  categoryName  String

  subcategory SubCategory[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

//
// =====================================
// SUBCATEGORY
// =====================================
//
model SubCategory {
  subCategoryId String     @id @default(cuid())
  subCategoryName          String

  categoryId    String
  category      Category   @relation(fields: [categoryId], references: [categoryId])

  service      Service[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}


model Service {
  serviceId   String  @id @default(cuid())
  name        String
  description String
  points      Json?
  photoUrl    String

  serviceType String // one_time | recurring
  frequency   Frequency? // monthly | quarterly | yearly
  duration    String?    // eg: 12
  durationUnit DurationUnit? // month | Stringr

 documentsRequired String @default("false") 
 requiredDocuments Json?

  // Pricing 
  individualPrice String 
  offerPrice String?
 isGstApplicable String @default("true")
  gstPercentage String? 
  finalIndividualPrice String 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  myService         MyService[]   
  inputFields ServiceInputField[]
  trackSteps  ServiceTrackStep[] 
  application Application[]

  bundles     ServiceBundle[]  @relation("BundleServices")

  employeeId String
  employee    Employee @relation(fields:[employeeId], references: [employeeId])

  subCategoryId   String
  subCategory     SubCategory @relation(fields: [subCategoryId], references: [subCategoryId])
}

model MyService {
  myServiceId String @id @default(cuid())
  userId      String
  user   User @relation(fields: [userId], references: [userId])

  serviceId String?
  bundleId  String?


  status    MyServiceStatus @default(NOT_STARTED)
  createdAt DateTime @default(now())
  application Application?
  service Service? @relation(fields: [serviceId], references: [serviceId])
  serviceBundle ServiceBundle? @relation(fields: [bundleId], references: [bundleId])

}


model MasterInputField {
  masterFieldId String   @id @default(cuid())
  label         String
  type          String  // text, number, file, email, date, select, textarea
  placeholder   String
  options       Json?   // <-- add this field to store dropdown options
  required Boolean @default(false)
  serviceFields ServiceInputField[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// -----------------------------
// SERVICE INPUT FIELDS
// -----------------------------
model ServiceInputField {
  fieldId  String  @id @default(cuid())
  label    String
  type     String // text, number, file, email, date, select, textarea
  options       Json?   // <-- add this field to store dropdown options
  placeholder String
  required Boolean @default(false)

    // NEW GLOBAL FIELD LINK
  masterFieldId  String
  masterField    MasterInputField  @relation(fields: [masterFieldId], references: [masterFieldId])

  // relation
  serviceId String
  service   Service @relation(fields: [serviceId], references: [serviceId])

  createdAt DateTime @default(now())
}

// -----------------------------
// SERVICE TRACK STEPS
// -----------------------------
model ServiceTrackStep {
  stepId String @id @default(cuid())
  title  String
  order  Int
  description String
  isCompleted Boolean @default(false) 

  // relation
  serviceId String
  service   Service @relation(fields: [serviceId], references: [serviceId])

  createdAt DateTime @default(now())
}

model ServiceBundle {
  bundleId     String      @id @default(cuid())
  name         String
  description  String?

  photoUrl     String
  
  // Pricing 
  bundlePrice Int 
  bundleOfferPrice Int?
  isGstApplicable Boolean @default(true)
  gstPercentage Int? 
  finalBundlePrice Int 

  services    Service[]   @relation("BundleServices")
  application Application[]
  myService   MyService[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model ApplicationHistory {
  historyId String @id @default(cuid())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [applicationId])

  applicationTrackStepId String?
  servicePeriodId        String?
  periodStepId           String?
  documentId             String?

  action      HistoryAction
  oldValue    String?
  newValue    String?

  doneByRole  String   // USER | STAFF | ADMIN | SYSTEM
  doneById    String?

  message     String?

  createdAt   DateTime @default(now())
}

model Application {
  applicationId String            @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [userId])


  // Optional: Service or Bundle
  serviceId     String?
  bundleId      String?

  service       Service?          @relation(fields: [serviceId], references: [serviceId])
  bundle        ServiceBundle?    @relation(fields: [bundleId], references: [bundleId])

  myServiceId String  @unique
  myService MyService @relation(fields: [myServiceId], references: [myServiceId])
  

  // Assigned employee
  employeeId    String?
  employee      Employee?         @relation(fields: [employeeId], references: [employeeId])

  // Dynamic form data (label, type, required)
  formData      Json?
  adminNote String?

  status        ApplicationStatus   @default(PENDING)

  // Live progress tracking
  applicationTrackStep    ApplicationTrackStep[]
  servicePeriod   ServicePeriod[]
  applicationHistory ApplicationHistory[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ApplicationTrackStep {
  applicationTrackStepId String @id @default(cuid())

  title       String
  order       Int
  description String?
  remarks       String?      // Optional comments or notes
  updatedById String?
  updatedBy   Employee? @relation(fields: [updatedById], references: [employeeId])

  status StepStatus @default(PENDING)

  // relation
  applicationId String
  application   Application @relation(fields: [applicationId], references: [applicationId])

  serviceDocument   ServiceDocument[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServicePeriod {
  servicePeriodId String @id @default(cuid())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [applicationId])

  periodLabel String // Jan 2025, Feb 2025
  startDate   DateTime   // 🔥 NEW
  endDate     DateTime   // 🔥 NEW
  isLocked    Boolean    @default(false)
  status ApplicationStatus @default(PENDING) 
  statusUpdatedAt DateTime @default(now()) // 🟢 ADDED

  completionPercent Int @default(0)        // 🟢 ADDED

  
  periodStep PeriodStep[]
 

  createdAt DateTime @default(now())
}

model PeriodStep {
  periodStepId String @id @default(cuid())
  servicePeriodId String
  servicePeriod   ServicePeriod @relation(fields: [servicePeriodId], references: [servicePeriodId])

  title       String
  order       Int
  description String?
  remarks     String?
  updatedById String?
  updatedBy   Employee? @relation(fields: [updatedById], references: [employeeId])

  status StepStatus @default(PENDING)
  serviceDocument ServiceDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceDocument {
  documentId String @id @default(cuid())

  applicationTrackStepId  String?
  applicationTrackStep   ApplicationTrackStep? @relation(fields: [applicationTrackStepId], references: [applicationTrackStepId])

  periodStepId String?
  periodStep   PeriodStep? @relation(fields: [periodStepId], references: [periodStepId])

  flow DocumentFlow @default(REQUESTED)

  requestedBy String?  
  uploadedBy  String? // user | staff

  documentType String // bill | challan | gst_return | certificate
  inputType  String

  fileUrl String?
  textValue    String? 

  version Int @default(0) // re-upload increases version
  remark  String?
  status       DocumentStatus @default(PENDING)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum DocumentStatus {
  PENDING
  FOR_REVIEW
  VERIFIED
  REJECTED
}

enum DocumentFlow {
  REQUESTED
  ISSUED
}

enum HistoryAction {
    APPLICATION_CREATED
    APPLICATION_STEPS_CREATED
    PERIODS_GENERATED
    SERVICE_STARTED
    DOCUMENTS_AUTO_REQUESTED
    APPLICATION_REASSIGNED
    APPLICATION_ASSIGNED
    STEP_UPDATED
    PERIOD_STEP_UPDATED
    DOCUMENT_UPLOADED
    DOCUMENT_REQUESTED
    DOCUMENT_ISSUED
    DOCUMENT_VERIFIED
    DOCUMENT_REJECTED
}